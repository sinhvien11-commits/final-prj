rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function role() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role;
    }
    function isKitchenOrAdmin() {
      return request.auth != null && role() in ['kitchen', 'admin'];
    }
    function isAdmin() {
      return request.auth != null && role() == 'admin';
    }

    match /menuItems/{itemId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if true;

      // Fix 2: validate status == 'received' + required fields on create
      allow create: if request.resource.data.status == 'received'
        && request.resource.data.machineNo is number
        && request.resource.data.items is list
        && request.resource.data.total is number;

      allow update: if isKitchenOrAdmin();
      allow delete: if isAdmin();
    }

    // Service requests from the customer screen. Anyone (guest) can create a
    // valid request; only signed-in staff (kitchen/admin) can read & resolve.
    match /serviceRequests/{id} {
      allow create: if request.resource.data.machineNo is number
        && request.resource.data.type in ['extend', 'assist']
        && request.resource.data.status == 'pending';
      allow read, update: if isKitchenOrAdmin();
    }

    // Play-time session per machine (doc id = machineNo). Guests (not signed in)
    // need to start/refresh their own session, mirroring how orders allow guest
    // creates — writes are gated on a valid shape only. Delete is denied
    // (request.resource.data is null → the field checks fail).
    match /playSessions/{machineNo} {
      allow read: if true;
      allow write: if request.resource.data.machineNo is number
        && request.resource.data.startedAt is timestamp
        && request.resource.data.dayKey is string;
    }

    match /profiles/{uid} {
      // Fix 1: non-admin cannot change the role field (prevent self-promote)
      allow update: if request.auth != null
        && request.auth.uid == uid
        && (!('role' in request.resource.data) || isAdmin());

      allow read: if request.auth != null && request.auth.uid == uid;

      // Admin can read/write any profile
      allow read, write: if isAdmin();
    }
  }
}
