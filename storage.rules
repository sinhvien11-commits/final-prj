rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /menu-images/{imageId} {
      allow read: if true;
      // Fix: only admin can upload menu images (capability matrix: anon/kitchen cannot)
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
